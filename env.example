// generative ai configs
GOOGLE_GENERATIVE_AI_API_KEY=***********

// authentication settings
NEON_DATABASE_URL=*****
BETTER_AUTH_SECRET=*****
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

// optional auth URL overrides
// locally, Better Auth defaults to http://localhost:3000
// on Vercel, BETTER_AUTH_URL is derived automatically from VERCEL_* env vars
// NEXT_PUBLIC_BETTER_AUTH_URL can stay unset to use same-origin /api/auth on the client
BETTER_AUTH_URL=
NEXT_PUBLIC_BETTER_AUTH_URL=
